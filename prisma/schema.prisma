generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum HabitDirection {
  BUILD
  REDUCE
}

enum AssistantTone {
  SUPPORTIVE
  DIRECT
  ANALYTICAL
  CHALLENGING
}

enum BlockPeriod {
  MORNING
  MIDDAY
  AFTERNOON
  EVENING
}

enum NudgeType {
  REMINDER
  ENCOURAGEMENT
  ACCOUNTABILITY
}

enum GroceryCategory {
  PRODUCE
  PROTEIN
  DAIRY
  PANTRY
  FROZEN
  SPICES
  OTHER
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  passwordHash     String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  profile          Profile?
  goals            Goal[]
  habits           Habit[]
  dailyPlans       DailyPlan[]
  reflections      Reflection[]
  mealPlans        MealPlan[]
  nudgePreference  NudgePreference?
}

model Profile {
  id                 String         @id @default(cuid())
  userId             String         @unique
  wakeTime           String
  sleepTime          String
  responsibilities   String
  topPriorities      String
  mealPreferences    String
  dietaryRestrictions String
  cookingStyle       String
  tone               AssistantTone  @default(SUPPORTIVE)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String
  progress    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Habit {
  id          String          @id @default(cuid())
  userId      String
  title       String
  direction   HabitDirection
  consistency Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyPlan {
  id              String       @id @default(cuid())
  userId          String
  date            DateTime
  topLine         String
  keystoneActions Json
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks          DailyBlock[]
}

model DailyBlock {
  id          String      @id @default(cuid())
  dailyPlanId String
  period      BlockPeriod
  title       String
  summary     String
  startTime   String
  endTime     String
  createdAt   DateTime    @default(now())
  dailyPlan   DailyPlan   @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)
}

model Reflection {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  moved     String
  felt      String
  aligned   String
  score     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MealPlan {
  id        String        @id @default(cuid())
  userId    String
  weekOf    DateTime
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals     Meal[]
}

model Meal {
  id          String        @id @default(cuid())
  mealPlanId  String
  dayLabel    String
  mealType    String
  title       String
  description String
  category    String
  createdAt   DateTime      @default(now())
  mealPlan    MealPlan      @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  groceries   GroceryItem[]
}

model GroceryItem {
  id         String          @id @default(cuid())
  mealId     String
  label      String
  category   GroceryCategory
  quantity   String
  checked    Boolean         @default(false)
  createdAt  DateTime        @default(now())
  meal       Meal            @relation(fields: [mealId], references: [id], onDelete: Cascade)
}

model NudgePreference {
  id                String      @id @default(cuid())
  userId            String      @unique
  enabled           Boolean     @default(true)
  reminderEnabled   Boolean     @default(true)
  encouragementEnabled Boolean   @default(true)
  accountabilityEnabled Boolean  @default(false)
  cadence           Int         @default(3)
  quietHoursStart   String      @default("21:00")
  quietHoursEnd     String      @default("07:00")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}
